### [<RpcApi>]
### type IOrderApi =
###    abstract GetProduct : int -> Async<Product>
###    abstract PlaceOrder : Order -> Async<OrderSummary>
###    abstract ListProducts : unit -> Async<Product list>

### Get Product
POST http://localhost:5050/rpc/IOrderApi/GetProduct
Content-Type: application/json
Accept: application/json

42

### Place Order (Requires X-Api-Key: ABC)
POST http://localhost:5050/rpc/IOrderApi/PlaceOrder
Content-Type: application/json
Accept: application/json
X-Api-Key: ABC

{"Id":1,"Lines":[{"Product":{"Id":{"Value":42},"Name":"Widget","Price":9.99,"Tags":[]},"Quantity":3}],"Notes":null}


